rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "bmporter12@gmail.com" && request.auth.token.email_verified == true));
    }

    function isProjectReader() {
      return (resource.data.publicAccess == true) || (isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.collaborators[request.auth.uid] in ['reader', 'editor'] ||
        isAdmin()
      ));
    }

    function isProjectEditor() {
      return isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.collaborators[request.auth.uid] == 'editor' ||
        isAdmin()
      );
    }

    function isValidUsageLog(data) {
      return data.keys().hasAll(['userId', 'model', 'totalTokens', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.totalTokens is number &&
             data.timestamp is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if isProjectReader();
      allow create: if isAuthenticated();
      allow update: if isProjectEditor();
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.ownerId || isAdmin());

      match /graphs/{graphId} {
        allow read: if isProjectReader();
        allow write: if isProjectEditor();

        match /nodes/{nodeId} {
          allow read: if isProjectReader();
          allow write: if isProjectEditor();
        }

        match /edges/{edgeId} {
          allow read: if isProjectReader();
          allow write: if isProjectEditor();
        }
      }

      match /snapshots/{snapshotId} {
        allow read: if isProjectReader();
        allow create: if isProjectEditor();
        allow delete: if isProjectEditor();
      }

      match /comments/{commentId} {
        allow read: if isProjectReader();
        allow create: if isProjectEditor();
        allow update, delete: if isProjectEditor() && (request.auth.uid == resource.data.authorId || isAdmin());
      }

      match /presence/{userId} {
        allow read: if isProjectReader();
        allow write: if isOwner(userId);
      }
    }

    match /templates/{templateId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin(); // Only admins can manage templates
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /settings/{settingId} {
        allow read, write: if isOwner(userId) && request.resource.data.keys().hasOnly(['nodeTypes']);
      }

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /usage_logs/{logId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidUsageLog(request.resource.data);
    }
  }
}
